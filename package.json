{
  "name": "pokernow-discord-stats-tracker",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "tsc --noEmit",
    "start": "npm run start:bot",
    "start:bot": "tsx apps/bot/src/index.ts",
    "start:tracker": "tsx apps/tracker/src/index.ts",
    "start:workers": "tsx apps/workers/src/index.ts",
    "start:api": "tsx apps/api/src/index.ts",
    "dev:bot": "tsx watch apps/bot/src/index.ts",
    "dev:tracker": "tsx watch apps/tracker/src/index.ts",
    "dev:api": "tsx watch apps/api/src/index.ts",
    "dev:workers": "tsx watch apps/workers/src/index.ts",
    "db:generate": "prisma generate --schema packages/db/prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema packages/db/prisma/schema.prisma",
    "db:migrate:deploy": "prisma migrate deploy --schema packages/db/prisma/schema.prisma",
    "import:pokernow-csv": "tsx scripts/import-pokernow-csv.ts",
    "rebuild:pokernow-hands": "tsx scripts/rebuild-pokernow-hands.ts",
    "test": "node --import tsx --test tests/**/*.test.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.8.2",
    "@sentry/node": "^9.19.0",
    "bullmq": "^5.52.3",
    "discord.js": "^14.18.0",
    "dotenv": "^17.4.2",
    "fastify": "^5.3.3",
    "ioredis": "^5.4.1",
    "pino": "^9.7.0",
    "pino-pretty": "^13.1.1",
    "socket.io-client": "^2.5.0",
    "ws": "^8.18.2"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "@types/ws": "^8.5.13",
    "prisma": "^6.8.2",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
